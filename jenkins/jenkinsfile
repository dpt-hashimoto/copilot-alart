pipeline {
    agent any
    tools {
        maven 'Maven3.9.16'
        jdk 'java17'
    }
    stages {

        stage('Clean Workspace') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/dpt-hashimoto/copilot-alart.git'
            }
        }

        stage('Build') {
            steps {
                bat 'mvn -Dmaven.test.failure.ignore=true clean package'
            }
        }

        stage('Create Release') {
            steps {
        
                bat '''
                if exist release rmdir /S /Q release
                if exist release.zip del /Q release.zip
        
                mkdir release
                mkdir release\\app
        
                xcopy /E /I /Y bin release\\bin
                xcopy /E /I /Y target\\runtime release\\runtime
        
                copy target\\copilot-alart-1.0.0.jar release
        
                powershell -Command "Compress-Archive -Path release -DestinationPath release.zip -Force"
                '''
            }
        }
    }
    post {
        success {
            archiveArtifacts artifacts: 'release/**, release.zip', fingerprint: true
        }
    }
}